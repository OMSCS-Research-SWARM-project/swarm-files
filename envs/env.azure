# Main CrewAI LLM - Azure AI Foundry / Azure OpenAI
MODEL=azure/<your-model-name-here>

# Azure OpenAI / Foundry
AZURE_API_KEY=<your-azure-api-key-here>
EMBEDDER_AZURE_API_KEY=<your-azure-embedder-key-here>

# Use the same base endpoint that worked in your AzureOpenAI test script
AZURE_API_BASE=<api-base-here>
AZURE_API_VERSION=<api-version-here>



# Embeddings - Azure OpenAI ADA
EMBEDDER_PROVIDER=azure
EMBEDDER_MODEL=text-embedding-ada-002
EMBEDDER_API_VERSION=2023-05-15
EMBEDDER_AZURE_API_BASE=https://<your-embedder-base-here>.openai.azure.com
EMBEDDER_AZURE_DEPLOYMENT_ID=<your-embedder-id-here>
